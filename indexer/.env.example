# --- Indexer config ---
PORT=3001

# Sui GraphQL endpoint (NOT JSON-RPC — JSON-RPC removed April 2026).
SUI_GRAPHQL_URL=https://sui-testnet.mystenlabs.com/graphql

# compliance_vault package id (post-deploy). Leave blank to run in SEED/serve-only mode.
PACKAGE_ID=

# Poll loop interval (ms) and page size.
POLL_INTERVAL_MS=3000
POLL_PAGE_SIZE=50

# SQLite file. Use :memory: for ephemeral.
DB_PATH=./indexer.db

# If true, load fixture data on boot so the frontend can integrate before the
# contract is deployed. Real polling still runs if PACKAGE_ID is set.
SEED=false
