# ComplianceVault SDK — Stage B manual testnet e2e env.
# Copy to .env and fill. Load with: tsx --env-file=.env <script>.ts  (Node 20+)

# Funded testnet signer. bech32 string from `sui keytool export` (suiprivkey1...).
# NEVER commit a real value. signer.ts reads this via signerFromEnv().
SUI_PRIVATE_KEY=suiprivkey1...

# mock-anchor gate. Keep 'false' for the Stage C real path — the BatchProver
# mock-fence also blocks mock seal/walrus impls regardless. Set 'true' ONLY for
# the legacy Stage B mock-blob anchor-e2e.ts. anchorClient.ts:18.
ALLOW_MOCK_ANCHOR=false

# Filled by bootstrap-namespace.ts output (anchor-e2e reads these):
NAMESPACE_ID=0x...
WRITER_CAP_ID=0x...
NAMESPACE_INIT_VERSION=        # only needed for §6 explicit-shared-ref fallback
# Optional overrides:
# PACKAGE_ID=0xcb5cc6...
# GRPC_BASE_URL=https://fullnode.testnet.sui.io:443

# --- Stage C (Walrus + Seal) ---
# ORIGINAL published compliance_vault package id for the Seal IBE domain.
# REQUIRED — no silent default. Pin to the original id even after a package upgrade
# (a shifted domain makes every prior blob undecryptable).
SEAL_PACKAGE_ID=0xcb5cc62066b4bbc2e66961b48d5141f9cf3ec119e33a7f6d6ec235a1d413b14c
# Comma-separated 3 testnet Seal key-server OBJECT IDs (not URLs). See Seal docs.
SEAL_KEY_SERVER_IDS=0xKEYSERVER1,0xKEYSERVER2,0xKEYSERVER3
# Walrus storage duration (epochs).
WALRUS_EPOCHS=3
# Per-event plaintext (CBOR) cap in bytes; BatchProver fails loud above this.
MAX_EVENT_BYTES=65536
# Scoped test EngagementObject id for the prove-e2e id-binding self-check
# (namespace_id == NAMESPACE_ID, auditor_addr == signer, scope covers the probe ts/type).
ENGAGEMENT_ID=0x...
# WAL token note: the signer address MUST hold WAL (storage fees) in addition to
# SUI (gas) before running scripts/prove-e2e.ts.
